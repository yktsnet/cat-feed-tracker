# cat-feed-tracker / .env.example
# cp .env.example .env and fill in real values

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=cat_feed_tracker
DB_USER=cat_feed_tracker
DB_PASSWORD=your_db_password

# Pico W auth token (must match DEVICE_TOKEN on the Pico W)
DEVICE_TOKEN=change-me-to-random-string

# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
