# cat-feed-tracker / .env.example
# cp .env.example .env and fill in real values

# PostgreSQL (Docker Compose 用デフォルト値; 手動構成の場合は DB_HOST=localhost 等に変更)
DB_HOST=db
DB_PORT=5432
DB_NAME=cat_feed
DB_USER=cat_feed
DB_PASSWORD=cat_feed

# Pico W auth token (must match DEVICE_TOKEN on the Pico W)
DEVICE_TOKEN=change-me-to-random-string

# LINE Messaging API
LINE_CHANNEL_SECRET=your_line_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token

# Timezone and notification slots
TIMEZONE=Asia/Tokyo
NOTIFY_SLOTS=11:00,16:00,21:00
